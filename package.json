{
  "name": "netq",
  "version": "0.3.1",
  "description": "netq：面向开发/运维/普通用户的轻量交互式网络排查 CLI",
  "license": "MIT",
  "author": "AlexanderJ-Carter <121274570+AlexanderJ-Carter@users.noreply.github.com>",
  "type": "commonjs",
  "types": "./src/core.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderJ-Carter/netq.git"
  },
  "bugs": {
    "url": "https://github.com/AlexanderJ-Carter/netq/issues"
  },
  "homepage": "https://alexanderj-carter.github.io/netq/",
  "sideEffects": false,
  "exports": {
    ".": "./src/core.js",
    "./core": "./src/core.js"
  },
  "bin": {
    "netq": "bin/netq.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cli",
    "network",
    "diagnostics",
    "ping",
    "traceroute",
    "dns",
    "port",
    "devops"
  ],
  "scripts": {
    "start": "node bin/netq.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"bin/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"bin/**/*.js\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run lint && npm test"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "ora": "^7.0.1"
  }
}
